{
  "name": "cdc-wsl-build",
  "version": "2.5.7",
  "description": "For building Windows Subsystem Linux (WSL) images",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdcgov/ocio-wsl.git"
  },
  "keywords": [
    "wsl",
    "builds",
    "linux",
    "distro"
  ],
  "author": "Boris Ning",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cdcgov/ocio-wsl/issues"
  },
  "homepage": "https://github.com/cdcgov/ocio-wsl#readme",
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "semantic-release": "25.0.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "${version}",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/git",
        {
          "assets": ["package.json", "CHANGELOG.md"],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "images/ubuntu-24.04-cdc.wsl",
              "label": "Ubuntu 24.04 CDC WSL Image"
            },
            {
              "path": "images/fedora-43-cdc.wsl",
              "label": "Fedora 43 CDC WSL Image"
            },
            {
              "path": "images/checksums.txt",
              "label": "Checksums for integrity validation"
            },
            {
              "path": "images/manifest.json",
              "label": "WSL Distribution Manifest"
            }
          ]
        }
      ]
    ]
  }
}
